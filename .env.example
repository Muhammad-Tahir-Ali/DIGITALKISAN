# ============================================================
# Digital Kisan Mobile App — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file — it contains secrets.
# Expo exposes only EXPO_PUBLIC_ prefixed variables to client code.
# ============================================================

# Google Maps API key — enable Maps SDK for Android/iOS in Google Cloud Console
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Backend API base URL (no trailing slash)
EXPO_PUBLIC_API_URL=https://your-render-app.onrender.com/api/v1

# Stripe publishable key (safe to expose in client code)
# https://dashboard.stripe.com/test/apikeys
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
