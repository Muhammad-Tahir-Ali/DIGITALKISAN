{
  "expo": {
    "name": "DigitalKisan",
    "slug": "DigitalKisan",
    "scheme": "digitalkisan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.digitalkisan.app",
      "config": {
        "googleMapsApiKey": "AIzaSyChTkkd7Z4WoH7K4ClCYdm_LFBJbyTIEXs"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2E7D32"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.digitalkisan.app",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyChTkkd7Z4WoH7K4ClCYdm_LFBJbyTIEXs"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Digital Kisan needs your location to find nearby delivery jobs."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
